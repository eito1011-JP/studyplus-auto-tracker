{
  "name": "studyplus-auto-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "開発時間を ActivityWatch で自動計測し StudyPlus へ自動投稿する個人ツール",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "poll": "tsx src/poll.ts",
    "seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "launchd:install": "bash scripts/launchd-install.sh",
    "launchd:uninstall": "bash scripts/launchd-uninstall.sh"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "uuid": "^14.0.0"
  }
}
